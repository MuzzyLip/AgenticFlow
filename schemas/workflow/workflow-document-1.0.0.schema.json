{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-flow.dev/schema/workflow-document-1.0.0.json",
  "title": "WorkflowDocument",
  "type": "object",
  "required": ["schemaVersion", "workflowId", "meta", "graph"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "workflowId": {
      "type": "string",
      "minLength": 1
    },
    "meta": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "graph": {
      "type": "object",
      "required": ["nodes", "edges"],
      "additionalProperties": false,
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nodeInstance"
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/edgeInstance"
          }
        },
        "viewport": {
          "type": "object",
          "required": ["x", "y", "zoom"],
          "additionalProperties": false,
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            },
            "zoom": {
              "type": "number",
              "minimum": 0.1
            }
          }
        }
      }
    }
  },
  "$defs": {
    "portDefinition": {
      "type": "object",
      "required": ["id", "label", "direction", "valueType", "cardinality"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "enum": ["input", "output"]
        },
        "valueType": {
          "enum": [
            "control",
            "text",
            "number",
            "boolean",
            "json",
            "array",
            "object",
            "any"
          ]
        },
        "cardinality": {
          "enum": ["single", "multiple"]
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "nodeInstance": {
      "type": "object",
      "required": ["id", "type", "label", "position", "config", "ports"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "additionalProperties": false,
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            }
          }
        },
        "config": {
          "type": "object"
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/portDefinition"
          }
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nodeIoDefinition"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nodeIoDefinition"
          }
        },
        "inputBindings": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/inputBinding"
          }
        }
      }
    },
    "edgeEndpoint": {
      "type": "object",
      "required": ["nodeId", "portId"],
      "additionalProperties": false,
      "properties": {
        "nodeId": {
          "type": "string",
          "minLength": 1
        },
        "portId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "edgeInstance": {
      "type": "object",
      "required": ["id", "type", "source", "target"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "enum": ["control", "data"]
        },
        "source": {
          "$ref": "#/$defs/edgeEndpoint"
        },
        "target": {
          "$ref": "#/$defs/edgeEndpoint"
        },
        "branch": {
          "$ref": "#/$defs/edgeBranch"
        }
      }
    },
    "inputBinding": {
      "oneOf": [
        {
          "type": "object",
          "required": ["source", "value"],
          "additionalProperties": false,
          "properties": {
            "source": {
              "const": "const"
            },
            "value": {}
          }
        },
        {
          "type": "object",
          "required": ["source", "value"],
          "additionalProperties": false,
          "properties": {
            "source": {
              "const": "ref"
            },
            "value": {
              "type": "object",
              "required": ["nodeId", "outputId"],
              "additionalProperties": false,
              "properties": {
                "nodeId": {
                  "type": "string",
                  "minLength": 1
                },
                "outputId": {
                  "type": "string",
                  "minLength": 1
                },
                "path": {
                  "type": "string"
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["source", "value"],
          "additionalProperties": false,
          "properties": {
            "source": {
              "const": "context"
            },
            "value": {
              "type": "object",
              "required": ["key"],
              "additionalProperties": false,
              "properties": {
                "key": {
                  "type": "string",
                  "minLength": 1
                },
                "path": {
                  "type": "string"
                }
              }
            }
          }
        }
      ]
    },
    "nodeIoDefinition": {
      "type": "object",
      "required": ["id", "label", "valueType"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "valueType": {
          "enum": [
            "control",
            "text",
            "number",
            "boolean",
            "json",
            "array",
            "object",
            "any"
          ]
        },
        "fieldType": {
          "enum": [
            "text",
            "paragraph",
            "select",
            "number",
            "checkbox",
            "single_file",
            "multi_file",
            "json"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "maxLength": {
          "type": "integer",
          "minimum": 1
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "step": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              },
              "value": {
                "type": "string"
              }
            }
          }
        },
        "acceptedFileTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "maxFileSizeMb": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "maxFiles": {
          "type": "integer",
          "minimum": 1
        },
        "defaultValue": {},
        "description": {
          "type": "string"
        },
        "schema": {
          "type": "object"
        }
      }
    },
    "edgeBranch": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": ["default", "condition", "error"]
        },
        "label": {
          "type": "string"
        },
        "isFallback": {
          "type": "boolean"
        },
        "condition": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "expression": {
              "type": "string"
            },
            "expected": {
              "type": ["string", "number", "boolean"]
            }
          }
        }
      }
    }
  }
}
